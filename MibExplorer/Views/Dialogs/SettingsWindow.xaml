<Window x:Class="MibExplorer.Views.Dialogs.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
        Background="{DynamicResource AppPanelBrush}"
        BorderBrush="{DynamicResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="14"
        Padding="14">
                <Border Background="{DynamicResource AppPanelAltBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10">
                    <ListBox x:Name="SectionList"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{DynamicResource AppTextBrush}"
                 SelectionChanged="SectionList_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">

                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="14,10"/>
                                <Setter Property="Margin" Value="0,4,0,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="{DynamicResource AppSelectionBrush}"/>
                                                </Trigger>

                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="{DynamicResource AppControlHoverBrush}"/>
                                                </Trigger>

                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="{DynamicResource AppSelectionBrush}"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.Resources>

                        <ListBoxItem Content="General" IsSelected="True"/>
                        <ListBoxItem Content="Connection"/>
                        <ListBoxItem Content="Updates"/>
                    </ListBox>
                </Border>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <Grid x:Name="SectionHost">
                    <StackPanel x:Name="GeneralPanel">
                        <TextBlock Text="General"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>
                        <CheckBox x:Name="RememberWindowPlacementCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Remember window size and position"/>
                    </StackPanel>

                    <StackPanel x:Name="ConnectionPanel" Visibility="Collapsed">
                        <TextBlock Text="Connection"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Host"
                                   Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox x:Name="LastHostTextBox"
                                 Margin="0,6,0,10"/>

                        <TextBlock Text="Port"
                                   Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox x:Name="LastPortTextBox"
                                 Margin="0,6,0,10"/>

                        <TextBlock Text="Username"
                                   Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox x:Name="LastUsernameTextBox"
                                 Margin="0,6,0,10"/>

                        <CheckBox x:Name="UsePrivateKeyCheckBox"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Use private key authentication"
                                  Margin="0,4,0,14"/>

                        <TextBlock Text="Private key path"
                                   Foreground="{DynamicResource AppTextBrush}"/>
                        <TextBox x:Name="PrivateKeyPathTextBox"
                                 Margin="0,6,0,10"/>
                    </StackPanel>

                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <TextBlock Text="Updates"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="AutoCheckUpdatesCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Check for updates automatically at startup"/>

                        <CheckBox x:Name="IncludePrereleaseCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Include prerelease versions in update checks"
                                  Margin="0,10,0,0"/>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="When enabled, beta and prerelease versions are considered during update checks."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Width="90"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
