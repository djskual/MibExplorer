<Window x:Class="MibExplorer.Views.Dialogs.ThemedMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="CaptionText"
                   Grid.Row="0"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,14"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="IconBadge"
                    Width="40"
                    Height="40"
                    CornerRadius="20"
                    Background="{DynamicResource AppPanelAltBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                <TextBlock x:Name="IconText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="20"
                           FontWeight="SemiBold"/>
            </Border>

            <TextBlock x:Name="MessageText"
                       Grid.Column="1"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       Margin="0,1,0,0"
                       MaxWidth="360"
                       LineHeight="22"/>
        </Grid>

      <Grid Grid.Row="2" Margin="0,18,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="CopyButton"
        Grid.Column="0"
        Width="28"
        Height="28"
        Padding="0"
        Background="Transparent"
        BorderThickness="0"
        ToolTip="Copy message"
        Cursor="Hand"
        Click="CopyButton_Click">

          <TextBlock Text="&#xE16F;"
                     FontFamily="Segoe MDL2 Assets"
                     FontSize="16"
                     Foreground="{DynamicResource AppTextBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Button>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button x:Name="CancelButton"
                  Content="Cancel"
                  Width="90"
                  Margin="0,0,8,0"
                  Visibility="Collapsed"
                  Click="CancelButton_Click"/>

          <Button x:Name="NoButton"
                  Content="No"
                  Width="90"
                  Margin="0,0,8,0"
                  Visibility="Collapsed"
                  Click="NoButton_Click"/>

          <Button x:Name="YesButton"
                  Content="Yes"
                  Width="90"
                  Margin="0,0,8,0"
                  Visibility="Collapsed"
                  Click="YesButton_Click"/>

          <Button x:Name="OkButton"
                  Content="OK"
                  Width="90"
                  Visibility="Collapsed"
                  Click="OkButton_Click"/>
        </StackPanel>
      </Grid>
    </Grid>
</Window>
