<Window x:Class="MibExplorer.Views.Dialogs.FileDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MibExplorer.ViewModels"
        Title="{Binding WindowTitle}"
        Width="1240"
        Height="780"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="Manual"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Window.Resources>
        <Style x:Key="DiffSegmentTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:FileDiffSegmentKind.Added}">
                    <Setter Property="Background" Value="#6636C275"/>
                    <Setter Property="Foreground" Value="#FFE8FFF3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:FileDiffSegmentKind.Removed}">
                    <Setter Property="Background" Value="#66D64545"/>
                    <Setter Property="Foreground" Value="#FFFFECEC"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaceholderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <Style x:Key="DiffListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Modified}">
                    <Setter Property="Background" Value="#22D69E2E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Added}">
                    <Setter Property="Background" Value="#2236C275"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Removed}">
                    <Setter Property="Background" Value="#22D64545"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.AddedPairPlaceholder}">
                    <Setter Property="Background" Value="#112236C2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.RemovedPairPlaceholder}">
                    <Setter Property="Background" Value="#11D64545"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Collapsed}">
                    <Setter Property="Background" Value="#161F2B3B"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="BorderBrush" Value="#AA6FA8FF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DiffMarkerTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Added}">
                    <Setter Property="Foreground" Value="#6EE7B7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Removed}">
                    <Setter Property="Foreground" Value="#FCA5A5"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding LineKind}" Value="{x:Static local:FileDiffLineKind.Modified}">
                    <Setter Property="Foreground" Value="#FCD34D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ChangeMarker}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Border Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="File diff"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding RemotePath}"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding SummaryText}"
                                   Foreground="{DynamicResource AppSubTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="24,0,0,0"
                                VerticalAlignment="Top">
                        <CheckBox Content="Ignore whitespace changes"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Margin="0,0,0,8"
                                  IsChecked="{Binding IgnoreWhitespace}"/>

                        <CheckBox Content="Show invisible characters"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Margin="0,0,0,8"
                                  IsChecked="{Binding ShowInvisibles}"/>

                        <CheckBox Content="Collapse unchanged sections"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  IsChecked="{Binding CollapseUnchanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource AppPanelAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Original"
                                       FontWeight="SemiBold"/>

                            <ListBox x:Name="OriginalListBox"
                                     Grid.Row="2"
                                     ItemsSource="{Binding OriginalLines}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource AppTextBrush}"
                                     ScrollViewer.CanContentScroll="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionMode="Single"
                                     SelectionChanged="OriginalListBox_SelectionChanged"
                                     ItemContainerStyle="{StaticResource DiffListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Margin="0,0,6,0"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding ChangeMarker}"
                                                       Style="{StaticResource DiffMarkerTextStyle}"/>

                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,8,0"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource AppSubTextBrush}"
                                                       FontFamily="Consolas"
                                                       FontSize="13"
                                                       Text="{Binding LineNumberText}"/>

                                            <Grid Grid.Column="2">
                                                <ItemsControl ItemsSource="{Binding Segments}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}"
                                                                       Style="{StaticResource DiffSegmentTextStyle}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding PlaceholderText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{DynamicResource AppPanelAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Current"
                                       FontWeight="SemiBold"/>

                            <ListBox x:Name="CurrentListBox"
                                     Grid.Row="2"
                                     ItemsSource="{Binding CurrentLines}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource AppTextBrush}"
                                     ScrollViewer.CanContentScroll="False"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectionMode="Single"
                                     SelectionChanged="CurrentListBox_SelectionChanged"
                                     ItemContainerStyle="{StaticResource DiffListBoxItemStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22"/>
                                                <ColumnDefinition Width="56"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Margin="0,0,6,0"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding ChangeMarker}"
                                                       Style="{StaticResource DiffMarkerTextStyle}"/>

                                            <TextBlock Grid.Column="1"
                                                       Margin="0,0,8,0"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{DynamicResource AppSubTextBrush}"
                                                       FontFamily="Consolas"
                                                       FontSize="13"
                                                       Text="{Binding LineNumberText}"/>

                                            <Grid Grid.Column="2">
                                                <ItemsControl ItemsSource="{Binding Segments}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}"
                                                                       Style="{StaticResource DiffSegmentTextStyle}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="{Binding PlaceholderText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PlaceholderTextStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Bottom"
                               Text="{Binding DiffPositionText}"
                               Foreground="{DynamicResource AppSubTextBrush}"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                        <Button Content="Previous diff"
                                Width="110"
                                Margin="0,0,8,0"
                                Click="PreviousDiff_Click"/>
                        <Button Content="Next diff"
                                Width="90"
                                Margin="0,0,8,0"
                                Click="NextDiff_Click"/>
                        <Button Content="Close"
                                Width="90"
                                IsCancel="True"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>