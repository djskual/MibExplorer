<Window x:Class="MibExplorer.Views.Dialogs.FileEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="{Binding WindowTitle}"
        Width="980"
        Height="700"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="Manual"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <Window.InputBindings>
        <KeyBinding Key="S"
                    Modifiers="Control"
                    Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Grid Margin="14">
        <Border Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Remote file editor"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding RemotePath}"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding ModeLabel}"
                                   Foreground="{DynamicResource AppSubTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Top"
                                Margin="16,2,0,0">
                        <CheckBox x:Name="InlineDiffToggle"
                                  HorizontalAlignment="Right"
                                  Content="Inline diff"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  IsChecked="True"
                                  Checked="InlineDiffToggle_Changed"
                                  Unchecked="InlineDiffToggle_Changed"
                                  ToolTip="Highlight added and modified lines directly in the editor."/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button x:Name="PreviousDiffButton"
                                    Width="24"
                                    Height="24"
                                    Margin="0,0,6,0"
                                    Padding="0"
                                    Content="◀"
                                    Click="PreviousDiffButton_Click"
                                    ToolTip="Go to previous difference"
                                    IsEnabled="False"/>

                            <Button x:Name="NextDiffButton"
                                    Width="24"
                                    Height="24"
                                    Padding="0"
                                    Content="▶"
                                    Click="NextDiffButton_Click"
                                    ToolTip="Go to next difference"
                                    IsEnabled="False"/>
                        </StackPanel>

                        <TextBlock x:Name="DiffNavigationText"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Right"
                                   Text="0 / 0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   FontSize="11"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Background="{DynamicResource AppPanelAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10">
                  <avalonedit:TextEditor x:Name="EditorTextBox"
                                           ShowLineNumbers="True"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Background="Transparent"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           BorderThickness="0"
                                           IsEnabled="{Binding IsEditorEnabled}"
                                           IsReadOnly="{Binding IsReadOnly}"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"
                                           SyntaxHighlighting="{x:Null}"/>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Image Width="18"
                               Height="18"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding LoadingIndicatorVisibility}"
                               gif:ImageBehavior.AnimatedSource="pack://application:,,,/Assets/throbber.gif"
                               gif:ImageBehavior.RepeatBehavior="Forever"/>

                        <TextBlock VerticalAlignment="Center"
                                   Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource AppSubTextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Diff"
                                Width="90"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanShowDiff}"
                                Click="Diff_Click"/>
                        <Button Content="Reload"
                                Width="90"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanReload}"
                                Click="Reload_Click"/>
                        <Button Content="Save"
                                Width="90"
                                Margin="0,0,8,0"
                                Command="{Binding SaveCommand}"/>
                        <Button Content="Close"
                                Width="90"
                                IsCancel="True"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>