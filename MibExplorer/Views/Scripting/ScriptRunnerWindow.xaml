<Window x:Class="MibExplorer.Views.Scripting.ScriptRunnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="Script Center"
        Height="710"
        Width="1100"
        MinHeight="710"
        MinWidth="800"
        WindowStartupLocation="Manual"
        Background="{DynamicResource AppWindowBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="ScriptListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource AppControlBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer Focusable="False"
                                          Padding="{TemplateBinding Padding}">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScriptListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource AppControlHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource AppSelectionBrush}" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="16"
          Background="{DynamicResource AppWindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <GroupBox Header="Scripts">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Scripts folder:"
                                   Margin="0,0,0,6"
                                   FontWeight="SemiBold" />

                        <TextBox Text="{Binding ScriptsFolderPath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 ToolTip="{Binding ScriptsFolderPath}"
                                 HorizontalScrollBarVisibility="Auto"
                                 Margin="0,0,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0"
                                    Content="Browse..."
                                    MinWidth="100"
                                    Click="BrowseScriptsFolder_Click" />

                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="Open Folder"
                                    MinWidth="100"
                                    Command="{Binding OpenScriptsFolderCommand}" />

                            <Button Grid.Row="2" Grid.Column="0"
                                    Content="Refresh"
                                    MinWidth="100"
                                    Command="{Binding RefreshScriptsCommand}" />

                            <Button Grid.Row="2" Grid.Column="2"
                                    MinWidth="100"
                                    Command="{Binding UpdateOfficialScriptsCommand}"
                                    ToolTip="{Binding OfficialUpdateTooltip}">
                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Update Official"
                                               VerticalAlignment="Center" />

                                    <Ellipse Grid.Column="2"
                                             Width="12"
                                             Height="12"
                                             Fill="#F59E0B"
                                             Stroke="#FFF8E1"
                                             StrokeThickness="1"
                                             VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOfficialScriptUpdates}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Scripts}"
                             SelectedItem="{Binding SelectedScript}"
                             MouseDoubleClick="ScriptsListBox_MouseDoubleClick"
                             Style="{StaticResource ScriptListBoxStyle}"
                             ItemContainerStyle="{StaticResource ScriptListBoxItemStyle}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left side: official badge + name + path -->
                                    <StackPanel Grid.Column="0"
                                                Margin="0,0,8,0">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Official badge -->
                                            <TextBlock Grid.Column="0"
                                                       Margin="0,0,6,0"
                                                       FontSize="12"
                                                       Text="🛡"
                                                       VerticalAlignment="Center"
                                                       ToolTip="Official Script">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="Foreground" Value="#22C55E" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOfficial}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsModified}" Value="True">
                                                                <Setter Property="Foreground" Value="#EF4444" />
                                                                <Setter Property="ToolTip" Value="Official script modified locally" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Script name -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding ScriptTooltip}" />
                                        </Grid>

                                        <!-- Relative path -->
                                        <TextBlock Text="{Binding RelativePath}"
                                                   Margin="0,2,0,0"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>

                                    <!-- Right side: compact type icon -->
                                    <TextBlock Grid.Column="1"
                                               Margin="8,0,0,0"
                                               FontSize="12"
                                               VerticalAlignment="Top"
                                               HorizontalAlignment="Right"
                                               ToolTip="{Binding ScriptType}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="•"/>
                                                <Setter Property="Foreground" Value="#9CA3AF"/>

                                                <Style.Triggers>

                                                    <!-- ReadOnly -->
                                                    <DataTrigger Binding="{Binding IsReadOnlyType}" Value="True">
                                                        <Setter Property="Text" Value="👁"/>
                                                        <Setter Property="Foreground" Value="#22C55E"/>
                                                    </DataTrigger>

                                                    <!-- Apply -->
                                                    <DataTrigger Binding="{Binding IsApplyType}" Value="True">
                                                        <Setter Property="Text" Value="⚙"/>
                                                        <Setter Property="Foreground" Value="#F59E0B"/>
                                                    </DataTrigger>

                                                    <!-- Dangerous -->
                                                    <DataTrigger Binding="{Binding IsDangerousType}" Value="True">
                                                        <Setter Property="Text" Value="⚠"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </GroupBox>

            <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,16,14,0"
                Padding="8,3"
                CornerRadius="10"
                Panel.ZIndex="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#7F7F7F" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnectedToMib}" Value="True">
                                <Setter Property="Background" Value="#2E8B57" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <TextBlock Text="{Binding ConnectionStateText}"
                       Foreground="White"
                       FontSize="11"
                       FontWeight="SemiBold" />
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="240" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Details">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Name"
                               FontWeight="SemiBold" />

                    <TextBox Grid.Row="2"
                             Text="{Binding SelectedScript.Name, Mode=OneWay}"
                             IsReadOnly="True" />

                    <TextBlock Grid.Row="4"
                               Text="Type"
                               FontWeight="SemiBold" />

                    <StackPanel Grid.Row="6"
            Orientation="Horizontal"
            VerticalAlignment="Center">

                        <Border Padding="8,4"
            CornerRadius="10"
            HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#5A5A5A" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedScript.IsReadOnlyType}" Value="True">
                                            <Setter Property="Background" Value="#2E8B57" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedScript.IsApplyType}" Value="True">
                                            <Setter Property="Background" Value="#B8860B" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedScript.IsDangerousType}" Value="True">
                                            <Setter Property="Background" Value="#B22222" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,4,0"
                       Foreground="White"
                       FontSize="11"
                       Text="●" />
                                <TextBlock Text="{Binding SelectedScript.ScriptType, Mode=OneWay}"
                       Foreground="White"
                       FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="16,0,0,0"
               VerticalAlignment="Center"
               Foreground="{DynamicResource AppMutedTextBrush}"
               Text="{Binding SelectedScript.VersionDisplay, Mode=OneWay}" />

                        <TextBlock Margin="16,0,0,0"
               VerticalAlignment="Center"
               Foreground="{DynamicResource AppMutedTextBrush}"
               Text="{Binding SelectedScript.AuthorDisplay, Mode=OneWay}" />
                    </StackPanel>

                    <TextBlock Grid.Row="8"
                               Text="Local path"
                               FontWeight="SemiBold" />

                    <TextBox Grid.Row="10"
                             Text="{Binding SelectedScript.LocalPath, Mode=OneWay}"
                             IsReadOnly="True" />

                    <TextBlock Grid.Row="12"
                               Text="Description"
                               FontWeight="SemiBold" />

                    <TextBox Grid.Row="14"
                             Text="{Binding SelectedScript.Description, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="60" />

                    <StackPanel Grid.Row="16" Orientation="Horizontal">
                        <Button Content="Run"
                                Width="90"
                                Margin="0,0,8,0"
                                Command="{Binding RunScriptCommand}" />

                        <Button Content="Open in Editor"
                                Width="120"
                                Margin="0,0,8,0"
                                Click="OpenInEditor_Click"
                                Command="{Binding OpenInEditorCommand}" />

                        <Button Content="Copy Log"
                                Width="90"
                                Margin="0,0,8,0"
                                Command="{Binding CopyLogCommand}" />

                        <Button Content="Clear Log"
                                Width="90"
                                Command="{Binding ClearLogCommand}" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Grid.Row="2">
                <GroupBox Header="Execution Log">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding StatusText}"
                                   FontWeight="SemiBold" />

                        <TextBox x:Name="ExecutionLogTextBox"
                                 Grid.Row="2"
                                 Text="{Binding OutputText, Mode=OneWay}"
                                 Style="{StaticResource LogTextBoxStyle}"
                                 TextChanged="ExecutionLogTextBox_TextChanged" />
                    </Grid>
                </GroupBox>

                <Image HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,18,16,0"
                       Width="18"
                       Height="18"
                       Panel.ZIndex="10"
                       Visibility="{Binding LoadingIndicatorVisibility}"
                       gif:ImageBehavior.AnimatedSource="pack://application:,,,/Assets/throbber.gif"
                       gif:ImageBehavior.RepeatBehavior="Forever"/>
            </Grid>
        </Grid>
    </Grid>
</Window>